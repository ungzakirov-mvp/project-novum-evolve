DATABASE_URL=postgresql://sd_user:sd_pass@db:5432/servicedesk
SECRET_KEY=change-this-to-random-secret-key-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DEBUG=True

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-from-botfather

# Inbound Email (IMAP) — для автоматического создания тикетов из писем
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=support@yourdomain.com
IMAP_PASSWORD=your-email-password-or-app-password
IMAP_FOLDER=INBOX
IMAP_CHECK_INTERVAL=60
IMAP_USE_SSL=True

# Outbound Email (SMTP) — для отправки уведомлений
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=support@yourdomain.com
